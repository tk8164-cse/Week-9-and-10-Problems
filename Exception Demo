import java.util.Scanner;
public class ExceptionDemo {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter a string: ");
        String userInput = scanner.next();
        System.out.println("\n--- Calling Unhandled Exception Method ---");
        generateException(userInput);
        System.out.println("\n--- Calling Handled Exception Method ---");
        handleException(userInput);
        scanner.close();
    }
    public static void generateException(String text) {
        int badIndex = text.length() + 5;
        System.out.println("Attempting to access index: " + badIndex);
        char ch = text.charAt(badIndex); 
        System.out.println("Character at index " + badIndex + " is: " + ch);
    }
    public static void handleException(String text) {
        int badIndex = text.length() + 5;
        try {
            System.out.println("Attempting to access index: " + badIndex);
            char ch = text.charAt(badIndex);
            System.out.println("Character: " + ch);
        } catch (StringIndexOutOfBoundsException e) {
            System.out.println("Error Caught: You tried to access an index that doesn't exist!");
            System.out.println("Exception message: " + e.getMessage());
        }
    }
}
