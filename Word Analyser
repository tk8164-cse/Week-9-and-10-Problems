import java.util.Scanner;
public class WordAnalyzer {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter your text:");
        String input = sc.nextLine();
        String[] words = splitText(input);
        String[][] wordData = mapWordLengths(words);
        int[] results = findMinMaxIndices(wordData);
        System.out.println("--- Analysis ---");
        System.out.println("Shortest word: " + wordData[results[0]][0] + " (Length: " + wordData[results[0]][1] + ")");
        System.out.println("Longest word: " + wordData[results[1]][0] + " (Length: " + wordData[results[1]][1] + ")");     
        sc.close();
    }
    public static String[] splitText(String text) {
        int wordCount = 0;
        boolean isWord = false;
        for (int i = 0; i < getManualLength(text); i++) {
            if (text.charAt(i) != ' ' && !isWord) {
                wordCount++;
                isWord = true;
            } 
else if (text.charAt(i) == ' ') {
                isWord = false;
            }
        }
        String[] words = new String[wordCount];
        String currentWord = "";
        int index = 0;
        for (int i = 0; i < getManualLength(text); i++) {
            char c = text.charAt(i);
            if (c != ' ') {
                currentWord += c;
            } 
else {
                if (!currentWord.equals("")) {
                    words[index++] = currentWord;
                    currentWord = "";
                }
            }
        }
        if (!currentWord.equals("")) {
            words[index] = currentWord;
        }
        return words;
    }
    public static int getManualLength(String str) {
        int count = 0;
        for (char c : str.toCharArray()) {
            count++;
        }
        return count;
    }
    public static String[][] mapWordLengths(String[] words) {
        String[][] data = new String[words.length][2];
        for (int i = 0; i < words.length; i++) {
            data[i][0] = words[i];
            int len = getManualLength(words[i]);
            data[i][1] = String.valueOf(len);
        }
        return data;
    }
    public static int[] findMinMaxIndices(String[][] wordData) {
        if (wordData.length == 0) return new int[]{0, 0};
        int minIdx = 0;
        int maxIdx = 0;        
        for (int i = 1; i < wordData.length; i++) {
            int currentLen = Integer.parseInt(wordData[i][1]);
            int minLen = Integer.parseInt(wordData[minIdx][1]);
            int maxLen = Integer.parseInt(wordData[maxIdx][1]);
            if (currentLen < minLen) minIdx = i;
            if (currentLen > maxLen) maxIdx = i;
        }
        return new int[]{minIdx, maxIdx};
    }
}
